{
  "name": "vue-diff-text",
  "private": false,
  "version": "1.5.0",
  "description": "Vue 3 components to display text and HTML differences with multiple diff strategies.",
  "main": "./dist/vue-diff-text.umd.js",
  "module": "./dist/vue-diff-text.mjs",
  "exports": {
    ".": {
      "import": "./dist/vue-diff-text.mjs",
      "require": "./dist/vue-diff-text.umd.js"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "diffblazer": "^1.0.1"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/node": "^20.19.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.6"
  },
  "keywords": [
    "vue",
    "vue3",
    "diff",
    "text-diff",
    "html-diff",
    "component"
  ],
  "author": "Steve McNiven-Scott",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitefinitysteve/vue-diff-text.git"
  },
  "bugs": {
    "url": "https://github.com/sitefinitysteve/vue-diff-text/issues"
  },
  "homepage": "https://github.com/sitefinitysteve/vue-diff-text#readme"
}
